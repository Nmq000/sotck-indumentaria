```
src/
├── main.jsx              # Entry point React
├── App.jsx               # Routing y layout principal
├── theme.js              # Design tokens (colores, tipografía)
├── lib/
│   └── supabase.js       # Cliente Supabase + helpers de BD
├── contexts/
│   └── AuthContext.jsx   # Estado global de autenticación
├── components/
│   ├── ui.jsx            # Componentes UI reutilizables
│   ├── Sidebar.jsx       # Barra lateral de navegación
│   └── QRModal.jsx       # Modal para ver/imprimir QR
└── views/
    ├── LoginView.jsx      # Pantalla de login
    ├── DashboardView.jsx  # Dashboard con métricas y alertas
    ├── StockView.jsx      # Tabla de inventario con filtros
    ├── ScanView.jsx       # Formulario de carga de stock
    └── SettingsView.jsx   # Configuración (solo admin)
```

